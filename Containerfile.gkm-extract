# ---- Dependency stage - follow KServe pattern with golang:1.25 ----
FROM golang:1.25 AS deps

WORKDIR /workspace
COPY mcv/ mcv/
COPY go.mod go.mod
COPY go.sum go.sum
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

# ---- Build stage (requires CGO for libgpgme) ----
FROM deps AS builder

# Install build dependencies for CGO
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgpgme-dev \
    libbtrfs-dev \
 && rm -rf /var/lib/apt/lists/*

COPY gkm-extract/ gkm-extract/
COPY pkg/ pkg/
COPY vendor/ vendor/
COPY Makefile Makefile

# Build with CGO enabled (required for containers/image library)
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    make build-gkm-extract

# ---- License stage (parallel with build on BuildKit) ----
